# Optional. Leave empty to use same-origin requests such as /api/auth/login.
# Set only the API origin when backend is on another host, for example:
# VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_API_BASE_URL=
# Frontend HTTP timeout. LLM calls can take longer than ordinary CRUD requests.
VITE_API_TIMEOUT_MS=180000
