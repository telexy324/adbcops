# This file contains development-only placeholders. Copy it to .env and replace
# every replace-* value before starting the stack. Never commit .env.

APP_ENV=dev
APP_PORT=8080
FRONTEND_PORT=5173
APP_TIMEZONE=Asia/Shanghai
VITE_API_BASE_URL=
VITE_API_TIMEOUT_MS=180000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=aiops
DB_PASSWORD=replace-with-a-random-local-password
DB_NAME=aiops
DB_SSLMODE=disable

JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRE_HOURS=12
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-admin-password

CREDENTIAL_MASTER_KEY=replace-with-a-32-byte-random-key
CREDENTIAL_KEY_VERSION=v1

FILE_STORAGE_TYPE=local
LOCAL_FILE_DIR=./data/uploads
MAX_UPLOAD_BYTES=52428800

RAG_TOP_K=5
RAG_RECALL_K=30
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
CONVERSATION_RECENT_ROUNDS=8

LOG_SAMPLE_MAX_LINES=500
LOG_SAMPLE_MAX_BYTES=262144
LOG_QUERY_MAX_HOURS=24
ES_QUERY_TIMEOUT_SECONDS=15
SSH_CONNECT_TIMEOUT_SECONDS=10

K8S_LOG_TAIL_LINES=300
K8S_LOG_MAX_BYTES=262144
K8S_LOG_PREVIOUS_ENABLED=true

PROM_QUERY_TIMEOUT_SECONDS=15
PROM_MAX_SERIES=200
PROM_MAX_POINTS=5000

WORKFLOW_TIMEOUT_SECONDS=300
WORKFLOW_NODE_TIMEOUT_SECONDS=60
WORKFLOW_MAX_PARALLEL=4

AGENT_MAX_STEPS=12
AGENT_MAX_SKILL_CALLS=20
AGENT_TIMEOUT_SECONDS=180
